# Clinical AI Governance Platform — environment variables
# Copy to .env and fill in values. Never commit .env.

# --- Core ---
ANTHROPIC_API_KEY=sk-ant-...

# --- MCP Server ---
FHIR_MCP_DB=data/fhir.db
FHIR_MCP_ACTOR=agent:dev
FHIR_MCP_AUDIT_FILE=data/audit.jsonl
FHIR_MCP_LOINC_RULES=data/loinc_rules.json

# --- Auth (unset = dev mode, all callers allowed) ---
# FHIR_MCP_PRINCIPALS=agent:prod,agent:staging
# FHIR_MCP_APPROVERS=dr.smith@org.com,dr.jones@org.com

# --- RAG ---
# Set to 1 in CI to skip ChromaDB startup (BM25-only mode)
FHIR_MCP_RAG_DISABLE_CHROMA=0

# --- HTTP server ---
PORT=8080
HOST=0.0.0.0
FHIR_MCP_ALLOWED_ORIGINS=https://claude.ai,https://api.claude.ai

# --- Agent ---
# FHIR_MCP_CMD=python -m fhir_mcp.server
